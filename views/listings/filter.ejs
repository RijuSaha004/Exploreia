<% layout("/layouts/boilerplate") %>

    <%- include("../includes/filterOptions.ejs") %>

        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
            <% for(let item of filteredListing){ %>
                <a href="/listings/<%= item._id %>" class="listing-link">
                    <div class="card col listing-card">
                        <img src="<%= item.image.url %>" class="card-img-top" alt="listing_image"
                            style="height: 20rem;">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%=item.title%>
                                </b>
                                <br>
                                &#8377 <%=item.price.toLocaleString("en-in")%> / Night
                                    <i class="tax-info"> &nbsp +18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
                <% }%>
        </div>