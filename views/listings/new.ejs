<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8">
            <h3>Create a new Listings</h3>
            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Enter Title Here" type="text" class="form-control"
                        required>
                    <div class="invalid-feedback">Title was required</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" placeholder="Enter description Here" type="text"
                        class="form-control" required></textarea>
                    <div class="invalid-feedback">Description was requirded</div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Upload listing image</label>
                    <input name="listing[image]" type="file" class="form-control">
                    <div class="valid-feedback">Image was optional</div>
                </div>
                <div class="row ">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" placeholder="Enter price Here" type="number" class="form-control"
                            required>
                        <div class="invalid-feedback">Price was required</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" placeholder="Enter country Here" type="text" class="form-control"
                            required>
                        <div class="invalid-feedback">Country was required</div>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label">Location</label>
                        <input name="listing[location]" placeholder="Enter location Here" type="text"
                            class="form-control" required>
                        <div class="invalid-feedback">Location was required</div>
                    </div>
                    <div class="mb-3 col-md-4">
                        <label for="category" class="form-label">Category</label>
                        <select name="listing[category]" id="category" class="form-select" required>
                            <option value="" selected disabled>Select a category</option>
                            <option value="None">None</option>
                            <option value="River">River</option>
                            <option value="Beach">Beach</option>
                            <option value="Mountain">Mountain</option>
                            <option value="Pool">Pool</option>
                            <option value="Villa">Villa</option>
                            <option value="Jungle">Jungle</option>
                            <option value="Snow">Snow</option>
                            <option value="Lake">Lake</option>
                            <option value="Camping">Camping</option>
                            <option value="City">City</option>
                        </select>
                        <div class="invalid-feedback">Please select a category</div>
                    </div>
                </div>

                <br>
                <button type="submit" class="btn mb-3 add-btn">Enter</button>
            </form>
        </div>
    </div>